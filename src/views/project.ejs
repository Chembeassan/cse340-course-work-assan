<%- include('partials/header') %>

<main>
    <div class="container">
        <div class="project-header">
            <h1><%= project.title %></h1>
            <div class="project-actions">
                <a href="/edit-project/<%= project.project_id %>" class="btn btn-edit">✏️ Edit Project</a>
                <a href="/project/<%= project.project_id %>/assign-categories" class="btn btn-categories">
                    🏷️ Edit Categories
                </a>
            </div>
        </div>
        
        <div class="project-details">
            <p><strong>Organization:</strong> <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a></p>
            <p><strong>Date:</strong> <%= new Date(project.project_date).toLocaleDateString() %></p>
            <p><strong>Location:</strong> <%= project.location %></p>
        </div>
        
        <div class="project-description">
            <h2>About This Project</h2>
            <p><%= project.description %></p>
        </div>
        
        <!-- Categories Section -->
        <% if (categories && categories.length > 0) { %>
            <div class="project-categories">
                <h2>Categories</h2>
                <div class="category-tags">
                    <% categories.forEach(category => { %>
                        <a href="/category/<%= category.category_id %>" class="category-tag">
                            <%= category.name %>
                        </a>
                    <% }) %>
                </div>
            </div>
        <% } else { %>
            <div class="project-categories">
                <h2>Categories</h2>
                <p>No categories assigned to this project.</p>
                <a href="/project/<%= project.project_id %>/assign-categories" class="btn btn-categories">
                    Add Categories
                </a>
            </div>
        <% } %>
        
        <p><a href="/projects">← Back to All Projects</a></p>
    </div>
</main>

<%- include('partials/footer') %>