<%- include('partials/header') %>

<main>
    <h1><%= project.title %></h1>
    
    <div class="project-details">
        <div class="project-description">
            <h2>About This Project</h2>
            <p><%= project.description %></p>
        </div>
        
        <div class="project-info">
            <h2>Project Information</h2>
            <p><strong>Date:</strong> <%= new Date(project.project_date).toLocaleDateString() %></p>
            <p><strong>Location:</strong> <%= project.location || 'TBD' %></p>
            <p>
                <strong>Partner Organization:</strong> 
                <a href="/organization/<%= project.organization_id %>">
                    <%= project.organization_name %>
                </a>
            </p>
        </div>
    </div>
    
    <p><a href="/projects">← Back to All Upcoming Projects</a></p>
</main>

<%- include('partials/footer') %>