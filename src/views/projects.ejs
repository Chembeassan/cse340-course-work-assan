<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>
    
    <div class="projects-grid">
        <% if (projects && projects.length > 0) { %>
            <ul>
                <% projects.forEach(project => { %>
                    <li>
                        <h2>
                            <a href="/project/<%= project.project_id %>">
                                <%= project.title %>
                            </a>
                        </h2>
                        <p><%= project.description %></p>
                        <p>
                            <strong>Date:</strong> <%= new Date(project.project_date).toLocaleDateString() %>
                        </p>
                        <p>
                            <strong>Location:</strong> <%= project.location || 'TBD' %>
                        </p>
                        <p>
                            <strong>Organization:</strong> 
                            <a href="/organization/<%= project.organization_id %>">
                                <%= project.organization_name %>
                            </a>
                        </p>
                    </li>
                <% }) %>
            </ul>
        <% } else { %>
            <p>No upcoming service projects found.</p>
        <% } %>
    </div>
</main>

<%- include('partials/footer') %>