<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>
    <header>
        <nav>
            <a href="/" class="logo">CSE 340 <span>Service Network</span></a>
            
            <!-- Mobile menu toggle button -->
            <button class="mobile-menu-btn" onclick="toggleMenu()" aria-label="Toggle navigation">
                ☰
            </button>
            
            <ul id="nav-menu">
                <li><a href="/">Home</a></li>
                <li><a href="/organizations">Organizations</a></li>
                <li><a href="/projects">Projects</a></li>
                <li><a href="/categories">Categories</a></li>
            </ul>
        </nav>
    </header>

    <!-- Flash Messages -->
    <% const messages = flash(); %>
    <% Object.keys(messages).forEach(type => { %>
        <% if (messages[type].length > 0) { %>
            <div class="alert <%= type %>">
                <% messages[type].forEach(msg => { %>
                    <p><%= msg %></p>
                <% }); %>
            </div>
        <% } %>
    <% }); %>

    <!-- Mobile menu JavaScript -->
    <script>
        function toggleMenu() {
            const menu = document.getElementById('nav-menu');
            menu.classList.toggle('open');
        }

        // Close menu when a link is clicked (on mobile)
        document.querySelectorAll('#nav-menu a').forEach(link => {
            link.addEventListener('click', function() {
                const menu = document.getElementById('nav-menu');
                menu.classList.remove('open');
            });
        });

        // Close menu when clicking outside
        document.addEventListener('click', function(event) {
            const menu = document.getElementById('nav-menu');
            const button = document.querySelector('.mobile-menu-btn');
            if (menu && button && menu.classList.contains('open') && 
                !menu.contains(event.target) && 
                !button.contains(event.target)) {
                menu.classList.remove('open');
            }
        });
    </script>