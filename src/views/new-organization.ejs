<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Organization - CSE 340 Service Network</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/header') %>
    
    <main class="container">
        <h1>Add New Organization</h1>
        
        <form action="/new-organization" method="POST" class="organization-form">
            <div class="form-group">
                <label for="name">Organization Name *</label>
                <input 
                    type="text" 
                    id="name" 
                    name="name" 
                    required 
                    maxlength="150"
                    placeholder="Enter organization name"
                    value="<%= formData ? formData.name : '' %>"
                >
                <small class="help-text">Between 3 and 150 characters</small>
            </div>
            
            <div class="form-group">
                <label for="description">Description *</label>
                <textarea 
                    id="description" 
                    name="description" 
                    required 
                    maxlength="500"
                    rows="4"
                    placeholder="Describe the organization's mission and work"
                ><%= formData ? formData.description : '' %></textarea>
                <small class="help-text">Maximum 500 characters</small>
            </div>
            
            <div class="form-group">
                <label for="contactEmail">Contact Email *</label>
                <input 
                    type="email" 
                    id="contactEmail" 
                    name="contactEmail" 
                    required
                    placeholder="Enter contact email"
                    value="<%= formData ? formData.contactEmail : '' %>"
                >
                <small class="help-text">Must be a valid email address</small>
            </div>
            
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Create Organization</button>
                <a href="/organizations" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </main>
    
    <%- include('partials/footer') %>
</body>
</html>